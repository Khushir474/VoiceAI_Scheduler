# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key
# Direct Postgres URL: Supabase dashboard → Project Settings → Database → URI (Transaction pooler or Direct connection)
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@HOST:PORT/postgres

# LLM APIs
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
LLM_PROVIDER=anthropic

# Vapi (Real Voice Calling)
# Get these from https://dashboard.vapi.ai
# VAPI_API_KEY: Your Vapi API key (for REST API calls)
# VAPI_ASSISTANT_ID: Your assistant configuration ID (optional, can be set per call)
VAPI_API_KEY=sk-real-vapi-api-key-here
VAPI_ASSISTANT_ID=your-assistant-id-here
VAPI_PHONE_NUMBER_ID=your-phone-number-id-here  # From Vapi dashboard → Phone Numbers

# Vapi Call Settings
# Webhook URL for Vapi to POST call state, transcript, and errors
# This should point to your backend: https://your-domain.com/api/webhook/vapi
VAPI_WEBHOOK_URL=https://localhost:8000/api/webhook/vapi
VAPI_WEBHOOK_SECRET=  # Set in Vapi dashboard → Webhooks → Secret (leave blank for local dev)
# Public URL Vapi will POST to for the get_daily_context tool call (must be reachable by Vapi)
# Use ngrok for local dev: ngrok http 8888 → set this to https://<ngrok-id>.ngrok-free.app/api/daily-context
VAPI_TOOL_SERVER_URL=https://your-domain.com/api/daily-context

# WebSocket settings for real-time transcript streaming
VAPI_WEBSOCKET_ENABLED=true
VAPI_WEBSOCKET_TIMEOUT_SECONDS=300

# ElevenLabs
ELEVENLABS_API_KEY=your-elevenlabs-key

# Google Calendar (OAuth 2.0)
# To get credentials:
# 1. Go to https://console.cloud.google.com/
# 2. Create a project and enable Google Calendar API
# 3. Create an OAuth 2.0 Client ID (Application type: Desktop)
# 4. Download credentials JSON for CLIENT_ID and CLIENT_SECRET
# 5. Run auth flow requesting scope: https://www.googleapis.com/auth/calendar.events
#    (calendar.readonly is NOT sufficient for event creation)
# NOTE: if your refresh token was issued with calendar.readonly, re-run the auth
# flow with the write scope and replace GOOGLE_CALENDAR_REFRESH_TOKEN below.
GOOGLE_CALENDAR_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=your-secret
GOOGLE_CALENDAR_REFRESH_TOKEN=your-refresh-token
# Optional: runtime access token (auto-refreshed)
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_TOKEN_EXPIRY=

# Google Maps
GOOGLE_MAPS_API_KEY=your-maps-key

# Weather API
WEATHER_API_KEY=your-weather-key
WEATHER_PROVIDER=openweather
# WEATHER_PROVIDER=weatherapi

# Twilio
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890
USER_PHONE_NUMBER=+1234567890

# iMessage Bridge
IMESSAGE_BRIDGE_URL=http://localhost:8001

# Apple iCal (CalDAV - cloud-based)
APPLE_ICAL_CALDAV_URL=https://caldav.icloud.com
APPLE_ICAL_USERNAME=your-apple-id@icloud.com
APPLE_ICAL_PASSWORD=your-app-specific-password

# Langfuse (Observability)
LANGFUSE_PUBLIC_KEY=your-public-key
LANGFUSE_SECRET_KEY=your-secret-key
LANGFUSE_ENABLED=true

# Application
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
